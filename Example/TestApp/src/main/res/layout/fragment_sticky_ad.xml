<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/stickyNestedScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Sticky Ad Example"
            android:textColor="#212121"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Scroll down — the banner stays sticky within its reserved area as you scroll past it, then exits at the bottom. This mirrors the Flutter AudienzzStickyAdWrapper behaviour."
            android:textColor="#757575"
            android:textSize="14sp" />

        <!-- Pre-ad paragraphs -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para1" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para2" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para3" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para4" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para5" />

        <!-- Sticky ad container 1 — added programmatically -->
        <FrameLayout
            android:id="@+id/stickyAdContainer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp" />

        <!-- Section 2 -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para6" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para7" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para8" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para9" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para10" />

        <!-- Sticky ad container 2 -->
        <FrameLayout
            android:id="@+id/stickyAdContainer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp" />

        <!-- Section 3 -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para11" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para12" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para13" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para14" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para15" />

        <!-- Sticky ad container 3 -->
        <FrameLayout
            android:id="@+id/stickyAdContainer3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp" />

        <!-- Section 4 -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para16" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para17" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para18" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para19" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para20" />

        <!-- Sticky ad container 4 -->
        <FrameLayout
            android:id="@+id/stickyAdContainer4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp" />

        <!-- Section 5 -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para21" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para22" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para23" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para24" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para25" />

        <!-- Sticky ad container 5 -->
        <FrameLayout
            android:id="@+id/stickyAdContainer5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp" />

        <!-- Tail content -->
        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para26" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para27" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para28" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para29" />

        <include layout="@layout/item_sticky_paragraph"
            android:id="@+id/para30" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
